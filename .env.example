# Copie este arquivo para .env e preencha suas chaves
# cp .env.example .env

# ── LLM (obrigatório) ────────────────────────────────────────────────────────
# Crie sua chave em https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Modelo Claude a usar (padrão: claude-haiku-4-5-20251001)
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ── Narração por voz (opcional) ──────────────────────────────────────────────
# Crie sua chave em https://elevenlabs.io (plano gratuito disponível)
ELEVENLABS_API_KEY=sk_...

# ── Banco de dados (opcional) ────────────────────────────────────────────────
# SQLite local — criado automaticamente, não precisa alterar
# DATABASE_URL=sqlite:///demo.db

# PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/mydb

# MySQL:
# DATABASE_URL=mysql+pymysql://user:password@localhost:3306/mydb

# SQL Server:
# DATABASE_URL=mssql+pyodbc://user:password@host/db?driver=ODBC+Driver+17+for+SQL+Server

# ── LangSmith — tracing opcional ─────────────────────────────────────────────
# LANGSMITH_API_KEY=ls__...
# LANGSMITH_PROJECT=lang-chat
